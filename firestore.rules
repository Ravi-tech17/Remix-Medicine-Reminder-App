rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: name, email, role, familyMembers, linkedDoctorId, emergencyContact
    //
    // Collection: medicines
    // Fields: userId, profileId, name, dosage, frequency, startDate, endDate, stock, minStock, isCritical, prescribedBy
    //
    // Collection: reminders
    // Fields: userId, profileId, medicineId, medicineName, dosage, reminderTime, status, isCritical
    //
    // Collection: history
    // Fields: userId, profileId, medicineId, medicineName, dateTaken, status, notes
    //
    // Collection: journal
    // Fields: userId, profileId, date, mood, symptoms, notes
    //
    // Collection: doctorPatientLinks
    // Fields: doctorId, patientId, status, permissions
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isDoctor() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'doctor';
    }

    function isLinkedDoctor(patientId) {
      return isAuthenticated() && exists(/databases/$(database)/documents/doctorPatientLinks/$(request.auth.uid + '_' + patientId));
    }

    // Validation Functions
    function isValidMedicine(data) {
      return data.userId is string && data.profileId is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.dosage is string && data.dosage.size() < 50;
    }

    function isValidReminder(data) {
      return data.userId is string && data.profileId is string &&
             data.status in ['pending', 'taken', 'missed'];
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isLinkedDoctor(userId);
      allow write: if isOwner(userId);
    }

    match /medicines/{medicineId} {
      allow read: if isDocOwner() || isLinkedDoctor(resource.data.userId);
      allow create: if isAuthenticated() && isValidMedicine(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if isDocOwner() && isValidMedicine(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /reminders/{reminderId} {
      allow read: if isDocOwner() || isLinkedDoctor(resource.data.userId);
      allow create: if isAuthenticated() && isValidReminder(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if isDocOwner() && isValidReminder(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /history/{historyId} {
      allow read: if isDocOwner() || isLinkedDoctor(resource.data.userId);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isDocOwner();
      allow delete: if isDocOwner();
    }

    match /journal/{journalId} {
      allow read: if isDocOwner() || isLinkedDoctor(resource.data.userId);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isDocOwner();
      allow delete: if isDocOwner();
    }

    match /doctorPatientLinks/{linkId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.doctorId || request.auth.uid == resource.data.patientId);
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.doctorId || request.auth.uid == resource.data.patientId);
    }
  }
}
